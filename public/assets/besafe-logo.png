		<header  id="site-header" class="header-footer-group" role="banner">
			<div  class="pre-header" id="pre-header">
				
				
<form action="https://www.hotellebalze.it/it/ricerca-conversazionale/#chat-section" method="get" class="pre-header-start-chat">
  <input type="text"
         placeholder="Fai una domanda"
         id="start-chat-input"
         class="start-chat-input"
         name="start-text">
  <div class="box-btn-conver-bar">
    <button id="start-chat-button" class="start-chat-button" type="submit">
      <i class="fa-light fa-magnifying-glass icon-search"></i> 
      AI Search    </button>
  </div>
</form>


<style>
#pre-header .pre-header-start-chat {
  display: flex !important;
  justify-content: center !important;
  align-items: stretch !important;
  width: 100% !important;
  max-width: 45% !important;
  background: white !important;
  border-radius: 70px !important;
}

#pre-header .pre-header-start-chat i.fa-search {
  position: absolute !important;
  color: #888888 !important;
  top: 11px !important;
  left: 12px !important;
  z-index: 1 !important;
  bottom: auto !important;
  font-size: 18px !important;
}

#pre-header .pre-header-start-chat input#start-chat-input {
  padding: 10px 40px 10px 40px !important;
  border-radius: 70px 70px 70px 70px !important;
  border: none !important;
}

#pre-header .pre-header-start-chat button#start-chat-button {
  padding: 8px 15px !important;
  border-radius: 70px 70px 70px 70px !important;
  display: flex !important;
  justify-content: center !important;
  align-items: center !important;
  flex-flow: nowrap !important;
  text-wrap-mode: nowrap !important;
  gap: 5px !important;
  position: relative !important;
  top: 0 !important;
  bottom: 0 !important;
  right: 0 !important;
  left: auto !important;
  background-color: #F4F5F9 !important;
  border: none !important;
  height: 79% !important;
  margin: auto !important;
  color: black !important;
  width: 183px !important;
  font-weight: 400 !important;
  text-transform: capitalize;
}

#pre-header .pre-header-start-chat button#start-chat-button svg {
  width: 25px !important;
}

#pre-header .pre-header-contacts {
  text-align: right !important;
}

body.showing-menu-modal #pre-header,
#site-header.sticky #pre-header {
  display: none !important;
}

#pre-header .elementor-shortcode {
  display: flex !important;
  justify-content: flex-end !important;
}

@property --gA {
  syntax: "<number>";
  inherits: false;
  initial-value: 0;
}

.box-btn-conver-bar {
    display: flex;
    flex-direction: column-reverse;
    align-items: center;
    gap: 10px;
    margin: 3px 15px;
    padding: 3px;
    border-radius: 25px;
    --gA: 0;
    background: linear-gradient(90deg, rgba(224, 97, 112, var(--gA)) 0%, rgba(253, 226, 31, var(--gA)) 33%, rgba(115, 195, 114, var(--gA)) 66%, rgba(50, 135, 255, var(--gA)) 100%), #fff;
    background-size: 300% 300%, auto;
    background-position: 0% 50%, 0 0;
    transition: --gA .25s ease;
    width: 255px;
    align-content: center;
    height: fit-content;
}

.box-btn-conver-bar:hover{
  --gA: 1;
  animation: boxGradientLoop 2s ease-in-out infinite alternate;
}

.box-btn-conver-bar.active{
  --gA: 0 !important;
  animation: none !important;
}

@keyframes boxGradientLoop{
  0%   { background-position: 0% 50%, 0 0; }
  100% { background-position: 100% 50%, 0 0; }
}

@media (max-width: 768px) {
  #pre-header .pre-header-start-chat {
    width: 100% !important;
    max-width: 100% !important;
  }

  .box-btn-conver-bar:hover {
    --gA: 0 !important;
    animation: none !important;
  }

  #pre-header .pre-header-start-chat button#start-chat-button {
    font-size: 13px !important;
    width: fit-content !important;
    margin: 0px !important;
  }

  #pre-header .box-btn-conver-bar {
    margin: 3px 5px !important;
    width: auto !important;
  }

  #pre-header .pre-header-start-chat input#start-chat-input {
    padding: 10px 20px 10px 20px !important;
    border: none !important;
    font-size: 13px !important;
    line-height: normal !important;
  }
}
</style>				
